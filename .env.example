# ─── Copy this file to .env and fill in your values ──────────────────────────
# NEVER commit .env to git — it is already in .gitignore

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRATION_MS=86400000

# ─── PostgreSQL (Neon.tech — recommended) ────────────────────────────────────
# Get from: https://console.neon.tech → Connection String (Pooled, sslmode=require)
DB_URL=jdbc:postgresql://your-project.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your_neon_password
# Leave these unset for H2 local dev (will use defaults)
# DB_DRIVER=org.postgresql.Driver
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ─── Groq AI ─────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_API_MODEL=llama3-8b-8192

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.vercel.app

# ─── Railway Environment Variables Checklist ──────────────────────────────────
# Set these in Railway → Service → Variables:
# DB_URL          = jdbc:postgresql://...neon.tech/neondb?sslmode=require
# DB_USERNAME     = neondb_owner
# DB_PASSWORD     = <from Neon dashboard>
# JWT_SECRET      = <generate with: openssl rand -base64 32>
# GROQ_API_KEY    = gsk_...
# GROQ_API_MODEL  = llama3-8b-8192
# ALLOWED_ORIGINS = https://your-frontend.vercel.app
# PORT            = 8080 (Railway sets this automatically)

# ─── Redis (optional — not required for production) ────────────────────────────
# Remove these if you don't use Redis (Caffeine cache handles caching now)
# REDIS_HOST=your-redis.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your_upstash_password
