# ─── Copy this file to .env and fill in your values ──────────────────────────
# NEVER commit .env to git — it is in .gitignore

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong 256-bit secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRATION_MS=86400000

# ─── PostgreSQL (Neon.tech) ──────────────────────────────────────────────────
# Get from: https://console.neon.tech → Connection string
DB_URL=jdbc:postgresql://your-project.neon.tech/fitness_db?sslmode=require
DB_USERNAME=your_neon_username
DB_PASSWORD=your_neon_password

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → Connect
REDIS_HOST=your-redis.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_password

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fitness_ai_logs?retryWrites=true&w=majority

# ─── Groq AI ─────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Service URLs (for inter-service communication) ──────────────────────────
USER_SERVICE_URL=http://localhost:8081
WORKOUT_SERVICE_URL=http://localhost:8082
NUTRITION_SERVICE_URL=http://localhost:8083
ANALYTICS_SERVICE_URL=http://localhost:8084
AI_SERVICE_URL=http://localhost:8085
