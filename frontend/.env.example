# Copy this to .env.local for local dev (git-ignored)
# On Vercel: set VITE_API_URL in the Environment Variables UI

# Local development (gateway on your machine)
VITE_API_URL=http://localhost:8080/api

# Production (replace with your Railway gateway URL after deploying)
# VITE_API_URL=https://your-gateway.up.railway.app/api
